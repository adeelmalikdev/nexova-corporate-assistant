# Copy this file to .env and fill in real values before running the app.

# Grok API authentication token
GROK_API_KEY=

# Grok API base URL
GROK_BASE_URL=https://api.x.ai/v1

# Grok model name
GROK_MODEL=grok-4.3

# JWT signing secret
JWT_SECRET_KEY=

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT expiry in minutes
JWT_EXPIRY_MINUTES=480

# ChromaDB persistence path
CHROMA_PERSIST_PATH=./chroma_store

# Sentence transformer embedding model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Cross-encoder reranker model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval top-k
TOP_K_RETRIEVAL=10

# Reranked top-k
TOP_K_RERANKED=3

# BM25 score weight
BM25_WEIGHT=0.4

# Dense score weight
DENSE_WEIGHT=0.6

# Minimum similarity threshold
SIMILARITY_THRESHOLD=0.3

# Enable development mode
DEV_MODE=False

# Async database URL
DATABASE_URL=sqlite+aiosqlite:///./nexova.db

# Maximum query length
MAX_QUERY_LENGTH=500

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes
LOCKOUT_MINUTES=15

# Temporary password expiry in hours
TEMP_PASSWORD_EXPIRY_HOURS=48
